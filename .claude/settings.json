{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npx husky init)",
      "Bash(npx biome:*)",
      "Bash(git rm:*)",
      "Bash(python3:*)",
      "Bash(git mv:*)",
      "Bash(npm run build:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/lint.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/loop.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/prompt.sh\""
          }
        ]
      }
    ]
  }
}
